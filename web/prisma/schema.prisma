generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
  invitations Invitation[]

  @@map("roles")
}

model Institution {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  apiKeyOpenai    String?  @map("api_key_openai")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  customAiKey     String?  @map("custom_ai_key")
  customAiModel   String?  @map("custom_ai_model")
  hasIntegratedAi Boolean      @default(false) @map("has_integrated_ai")
  users           User[]
  aiUsageLogs     AiUsageLog[]
  invitations     Invitation[]

  @@map("institutions")
}

model GlobalSettings {
  id            Int     @id @default(1)
  globalAiModel String? @map("global_ai_model")
  globalAiKey   String? @map("global_ai_key")
  savedAiKeys   Json?   @map("saved_ai_keys")
  usdToBrlRate  Float   @default(5.50) @map("usd_to_brl_rate")

  @@map("global_settings")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  fullName       String          @map("full_name")
  roleId         Int             @map("role_id")
  institutionId  Int?            @map("institution_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  exams          Exam[]
  questionGroups QuestionGroup[]
  questions      Question[]
  institution    Institution?    @relation(fields: [institutionId], references: [id])
  role           Role            @relation(fields: [roleId], references: [id])
  aiUsageLogs    AiUsageLog[]
  invitationsSent Invitation[]

  @@map("users")
}

model QuestionGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  teacherId   Int        @map("teacher_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  teacher     User       @relation(fields: [teacherId], references: [id])
  questions   Question[]

  @@map("question_groups")
}

model Question {
  id              Int              @id @default(autoincrement())
  content         String
  type            QuestionType
  points          Float            @default(1.0)
  teacherId       Int              @map("teacher_id")
  groupId         Int?             @map("group_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  referenceAnswer String?          @map("reference_answer")
  referenceDevelopment String?     @map("reference_development")
  correctionMode  String           @default("CONCEPTUAL") @map("correction_mode")
  exams           ExamQuestion[]
  options         QuestionOption[]
  group           QuestionGroup?   @relation(fields: [groupId], references: [id])
  teacher         User             @relation(fields: [teacherId], references: [id])

  @@map("questions")
}

model QuestionOption {
  id         Int      @id @default(autoincrement())
  content    String
  isCorrect  Boolean  @default(false) @map("is_correct")
  questionId Int      @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model Exam {
  id             Int              @id @default(autoincrement())
  title          String
  description    String?
  teacherId      Int              @map("teacher_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  accessCode     String?          @unique @map("access_code")
  status         ExamStatus       @default(DRAFT)
  showScore      Boolean          @default(false) @map("show_score")
  randomizeOrder Boolean          @default(false) @map("randomize_order")
  saveToBank     Boolean          @default(false) @map("save_to_bank")
  type           ExamType         @default(DIGITAL)
  answerKeyImages Json?           @map("answer_key_images")
  aiInstructions String?          @map("ai_instructions")
  totalScore     Float?           @map("total_score")
  questions      ExamQuestion[]
  submissions    ExamSubmission[]
  teacher        User             @relation(fields: [teacherId], references: [id])
  aiUsageLogs    AiUsageLog[]

  @@map("exams")
}

model ExamSubmission {
  id          Int       @id @default(autoincrement())
  examId      Int       @map("exam_id")
  studentName String?   @map("student_name")
  studentRa   String?   @map("student_ra")
  studentExamImages Json? @map("student_exam_images")
  isPhysical  Boolean   @default(false) @map("is_physical")
  answers     Json?
  score       Float?
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  isExpelled  Boolean   @default(false) @map("is_expelled")
  focusLoses  Int       @default(0) @map("focus_loses")
  correctionDetails Json? @map("correction_details")
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, studentRa])
  @@map("exam_submissions")
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int      @map("exam_id")
  questionId Int      @map("question_id")
  order      Int      @default(0)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("exam_questions")
}

enum ExamType {
  DIGITAL
  PHYSICAL
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
  MATH
  CUSTOM_HTML
}

enum ExamStatus {
  DRAFT
  WAITING
  STARTED
  FINISHED
}

model AiUsageLog {
  id               Int          @id @default(autoincrement())
  teacherId        Int          @map("teacher_id")
  institutionId    Int?         @map("institution_id")
  examId           Int?         @map("exam_id")
  modelUsed        String       @map("model_used")
  promptTokens     Int          @default(0) @map("prompt_tokens")
  completionTokens Int          @default(0) @map("completion_tokens")
  costInBRL        Float        @default(0.0) @map("cost_in_brl")
  createdAt        DateTime     @default(now()) @map("created_at")

  teacher     User         @relation(fields: [teacherId], references: [id])
  institution Institution? @relation(fields: [institutionId], references: [id])
  exam        Exam?        @relation(fields: [examId], references: [id], onDelete: SetNull)

  @@map("ai_usage_logs")
}

model Invitation {
  id            String   @id @default(uuid())
  email         String   @unique
  token         String   @unique
  roleId        Int      @map("role_id")
  institutionId Int      @map("institution_id")
  inviterId     Int      @map("inviter_id")
  status        String   @default("PENDING")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  role        Role        @relation(fields: [roleId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  inviter     User        @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

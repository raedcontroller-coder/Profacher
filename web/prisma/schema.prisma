generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model Institution {
  id              Int      @id @default(autoincrement())
  name            String
  slug            String   @unique
  apiKeyOpenai    String?  @map("api_key_openai")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  customAiKey     String?  @map("custom_ai_key")
  customAiModel   String?  @map("custom_ai_model")
  hasIntegratedAi Boolean  @default(false) @map("has_integrated_ai")
  users           User[]

  @@map("institutions")
}

model GlobalSettings {
  id            Int     @id @default(1)
  globalAiModel String? @map("global_ai_model")
  globalAiKey   String? @map("global_ai_key")

  @@map("global_settings")
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  fullName       String          @map("full_name")
  roleId         Int             @map("role_id")
  institutionId  Int?            @map("institution_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  exams          Exam[]
  questionGroups QuestionGroup[]
  questions      Question[]
  institution    Institution?    @relation(fields: [institutionId], references: [id])
  role           Role            @relation(fields: [roleId], references: [id])

  @@map("users")
}

model QuestionGroup {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  teacherId   Int        @map("teacher_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  teacher     User       @relation(fields: [teacherId], references: [id])
  questions   Question[]

  @@map("question_groups")
}

model Question {
  id              Int              @id @default(autoincrement())
  content         String
  type            QuestionType
  points          Float            @default(1.0)
  teacherId       Int              @map("teacher_id")
  groupId         Int?             @map("group_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  referenceAnswer String?          @map("reference_answer")
  correctionMode  String           @default("CONCEPTUAL") @map("correction_mode")
  exams           ExamQuestion[]
  options         QuestionOption[]
  group           QuestionGroup?   @relation(fields: [groupId], references: [id])
  teacher         User             @relation(fields: [teacherId], references: [id])

  @@map("questions")
}

model QuestionOption {
  id         Int      @id @default(autoincrement())
  content    String
  isCorrect  Boolean  @default(false) @map("is_correct")
  questionId Int      @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model Exam {
  id             Int              @id @default(autoincrement())
  title          String
  description    String?
  teacherId      Int              @map("teacher_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  accessCode     String?          @unique @map("access_code")
  status         ExamStatus       @default(DRAFT)
  showScore      Boolean          @default(false) @map("show_score")
  randomizeOrder Boolean          @default(false) @map("randomize_order")
  saveToBank     Boolean          @default(false) @map("save_to_bank")
  questions      ExamQuestion[]
  submissions    ExamSubmission[]
  teacher        User             @relation(fields: [teacherId], references: [id])

  @@map("exams")
}

model ExamSubmission {
  id          Int       @id @default(autoincrement())
  examId      Int       @map("exam_id")
  studentName String    @map("student_name")
  studentRa   String    @map("student_ra")
  answers     Json?
  score       Float?
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  isExpelled  Boolean   @default(false) @map("is_expelled")
  correctionDetails Json? @map("correction_details")
  exam        Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, studentRa])
  @@map("exam_submissions")
}

model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int      @map("exam_id")
  questionId Int      @map("question_id")
  order      Int      @default(0)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("exam_questions")
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  ESSAY
  MATH
  CUSTOM_HTML
}

enum ExamStatus {
  DRAFT
  WAITING
  STARTED
  FINISHED
}
